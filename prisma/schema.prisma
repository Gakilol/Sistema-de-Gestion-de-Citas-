generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empleado {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  nombre       String
  correo       String   @unique
  telefono     String?
  passwordHash String
  especialidad String?
  horario      Json?
  rol          RolUsuario @default(EMPLEADO)
  activo       Boolean  @default(true)
  
  citas        Cita[]   @relation("EmpleadoAsignado")
  citasCreadas Cita[]   @relation("CreadorCita")
  descansos    DescansoEmpleado[]
  bloqueos     BloqueoHorario[]
  vacaciones   VacacionesEmpleado[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Servicio {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  nombre      String
  descripcion String?
  duracion    Int
  precio      Float
  categoria   String?
  activo      Boolean  @default(true)

  citas       Cita[]
}

model Cita {
  id               String   @id @default(dbgenerated("gen_random_uuid()"))
  cliente_id       String?
  cliente_nombre   String
  cliente_telefono String?
  servicio_id      String
  empleado_id      String
  fecha            DateTime @db.Date
  hora             String
  duracion         Int
  precio           Float
  estado           EstadoCita @default(PENDIENTE)
  notas            String?
  metodo_pago      String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  created_by       String

  cliente          Cliente? @relation(fields: [cliente_id], references: [id])
  servicio         Servicio @relation(fields: [servicio_id], references: [id])
  empleado         Empleado @relation("EmpleadoAsignado", fields: [empleado_id], references: [id])
  creador          Empleado @relation("CreadorCita", fields: [created_by], references: [id])
  
  pagos            Pago[]

  @@index([empleado_id])
  @@index([estado])
  @@index([fecha])
}

model Pago {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  cita_id    String
  monto      Float
  metodo     String
  estado     EstadoPago @default(PENDIENTE)
  referencia String?
  fecha_pago DateTime?

  cita       Cita     @relation(fields: [cita_id], references: [id], onDelete: Cascade)
}

enum RolUsuario {
  EMPLEADO
  ADMIN
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
  REPROGRAMADA
}

enum EstadoPago {
  PENDIENTE
  COMPLETADO
  FALLIDO
  REEMBOLSADO
}

model DescansoEmpleado {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  empleado_id String
  dia_semana  Int      // 0=Domingo, 1=Lunes, ..., 6=Sábado
  hora_inicio String   // e.g. "13:00"
  hora_fin    String   // e.g. "14:00"
  empleado    Empleado @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id])
}

model BloqueoHorario {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  empleado_id String
  fecha       DateTime @db.Date
  hora_inicio String   // e.g. "10:00"
  hora_fin    String   // e.g. "12:00"
  motivo      String?
  empleado    Empleado @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id, fecha])
}

model VacacionesEmpleado {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  empleado_id  String
  fecha_inicio DateTime @db.Date
  fecha_fin    DateTime @db.Date
  estado       String   @default("APROBADO") // APROBADO, PENDIENTE
  empleado     Empleado @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id])
}

model Configuracion {
  id           String   @id @default("default")
  negocio      Json?    // { nombre, subtitulo, telefono, whatsapp, direccion, web, moneda, zona_horaria }
  horarios     Json?    // Default general schedule
  whatsapp     Json?    // { numero, confirmar, recordatorio, cancelacion, msgExtra }
  apariencia   Json?    // { tema, branding }
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  entidad      String   // Cita, Empleado, Servicio, Configuracion
  entidadId    String
  accion       String   // CREAR, ACTUALIZAR, ELIMINAR, CANCELAR
  detalles     Json?
  realizadoPor String?
  fecha        DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([fecha])
}

model Cliente {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  nombre    String
  telefono  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  citas     Cita[]
}

