generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empleado {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  nombre       String
  correo       String   @unique
  telefono     String?
  passwordHash String
  especialidad String?
  horario      Json?
  rol          RolUsuario @default(EMPLEADO)
  activo       Boolean  @default(true)
  
  citas        Cita[]   @relation("EmpleadoAsignado")
  citasCreadas Cita[]   @relation("CreadorCita")
  descansos    DescansoEmpleado[]
  bloqueos     BloqueoHorario[]
  vacaciones   VacacionesEmpleado[]
  resetTokens  PasswordResetToken[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Servicio {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  nombre       String
  descripcion  String?
  duracion     Int
  categoria    String?
  categoria_id String?
  activo       Boolean  @default(true)

  citas         Cita[]
  categoriaRel  Categoria?     @relation(fields: [categoria_id], references: [id], onDelete: SetNull)
  citaServicios CitaServicio[]
}

model Cita {
  id               String   @id @default(dbgenerated("gen_random_uuid()"))
  cliente_id       String?
  cliente_nombre   String
  cliente_telefono String?
  servicio_id      String
  empleado_id      String
  fecha            DateTime @db.Date
  hora             String
  duracion         Int
  estado           EstadoCita @default(PENDIENTE)
  notas            String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  created_by       String

  // Analytics tracking fields
  cancelled_at     DateTime? // Set when estado changes to CANCELADA
  completed_at     DateTime? // Set when estado changes to COMPLETADA
  no_show_at       DateTime? // Set when estado changes to NO_SHOW
  cancel_reason    String?   // Optional reason for cancellation

  cliente          Cliente? @relation(fields: [cliente_id], references: [id])
  servicio         Servicio @relation(fields: [servicio_id], references: [id])
  empleado         Empleado @relation("EmpleadoAsignado", fields: [empleado_id], references: [id])
  creador          Empleado @relation("CreadorCita", fields: [created_by], references: [id])
  citaServicios    CitaServicio[]

  whatsapp_reminder_sent    Boolean   @default(false)
  whatsapp_reminder_sent_at DateTime?

  @@index([empleado_id])
  @@index([estado])
  @@index([fecha])
  @@index([cliente_id])
  @@index([servicio_id])
  @@index([created_at])
  @@index([cancelled_at])
  @@index([completed_at])
  @@index([whatsapp_reminder_sent, fecha, estado])
}

enum RolUsuario {
  EMPLEADO
  ADMIN
  TECH_SUPPORT
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
  NO_SHOW
  REPROGRAMADA
}

model DescansoEmpleado {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  empleado_id String
  dia_semana  Int      // 0=Domingo, 1=Lunes, ..., 6=Sábado
  hora_inicio String   // e.g. "13:00"
  hora_fin    String   // e.g. "14:00"
  empleado    Empleado @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id])
}

model BloqueoHorario {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  empleado_id String
  fecha       DateTime @db.Date
  hora_inicio String   // e.g. "10:00"
  hora_fin    String   // e.g. "12:00"
  motivo      String?
  empleado    Empleado @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id, fecha])
}

model VacacionesEmpleado {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  empleado_id  String
  fecha_inicio DateTime @db.Date
  fecha_fin    DateTime @db.Date
  estado       String   @default("APROBADO") // APROBADO, PENDIENTE
  empleado     Empleado @relation(fields: [empleado_id], references: [id], onDelete: Cascade)

  @@index([empleado_id])
}

model Configuracion {
  id           String   @id @default("default")
  negocio      Json?    // { nombre, subtitulo, telefono, whatsapp, direccion, web, moneda, zona_horaria }
  horarios     Json?    // Default general schedule
  whatsapp     Json?    // { numero, confirmar, recordatorio, cancelacion, msgExtra }
  apariencia   Json?    // { tema, branding }
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()"))
  entidad      String   // Cita, Empleado, Servicio, Configuracion (kept for compatibility)
  entidadId    String   // (kept for compatibility)
  accion       String   // CREAR, ACTUALIZAR, ELIMINAR, CANCELAR (kept for compatibility)
  detalles     Json?    // (kept for compatibility)
  realizadoPor String?  // (kept for compatibility)
  fecha        DateTime @default(now()) // (kept for compatibility)

  // Nuevos campos de auditoría avanzada (opcionales para no romper registros antiguos)
  userId       String?
  userName     String?
  userEmail    String?
  userRole     String?
  action       String?
  module       String?
  entityType   String?
  entityId     String?
  entityName   String?
  description  String?
  status       String?
  ipAddress    String?
  userAgent    String?
  requestId    String?
  beforeData   Json?
  afterData    Json?
  metadata     Json?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([fecha])
  
  // Nuevos índices
  @@index([createdAt])
  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([status])
  @@index([entityType, entityId])
}

model Cliente {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  nombre    String
  telefono  String?
  correo    String?
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  citas     Cita[]
}

model Categoria {
  id        String     @id @default(dbgenerated("gen_random_uuid()"))
  nombre    String     @unique
  color     String?    @default("#6366f1")
  activo    Boolean    @default(true)
  orden     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  servicios Servicio[]
}

model CitaServicio {
  id          String   @id @default(dbgenerated("gen_random_uuid()"))
  cita_id     String
  servicio_id String
  duracion    Int
  orden       Int      @default(0)

  cita        Cita     @relation(fields: [cita_id], references: [id], onDelete: Cascade)
  servicio    Servicio @relation(fields: [servicio_id], references: [id], onDelete: Restrict)

  @@index([cita_id])
}

model PasswordResetToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()"))
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())
  request_ip String?

  empleado   Empleado @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
}


