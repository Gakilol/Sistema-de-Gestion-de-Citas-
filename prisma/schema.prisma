generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RolUsuario {
  CLIENTE
  EMPLEADO
  ADMIN
}

enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
  NO_ASISTIO
}

model Usuario {
  id             String           @id @default(uuid())
  nombre         String
  email          String           @unique
  passwordHash   String
  telefono       String?
  rol            RolUsuario       @default(CLIENTE)
  activo         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  perfilEmpleado PerfilEmpleado?
  citasCliente   Cita[]           @relation("ClienteCita")
  notificaciones Notificacion[]
}

model PerfilNegocio {
  id            String   @id @default(uuid())
  nombreNegocio String
  direccion     String
  telefono      String
  email         String
  moneda        String   @default("USD")
  zonaHoraria   String   @default("UTC")
}

model Servicio {
  id              String   @id @default(uuid())
  nombre          String
  descripcion     String?
  duracionMinutos Int
  precio          Float
  activo          Boolean  @default(true)
  createdAt       DateTime @default(now())
  
  citas           Cita[]
}

model PerfilEmpleado {
  id              String   @id @default(uuid())
  userId          String   @unique
  especialidad    String?
  colorCalendario String?

  usuario         Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
  horarios        Horario[]
  citas           Cita[]   @relation("EmpleadoCita")
}

model Horario {
  id          String         @id @default(uuid())
  empleadoId  String
  diaSemana   Int            // 0 = Domingo, 1 = Lunes, etc.
  horaInicio  String         // Ej: "09:00"
  horaFin     String         // Ej: "18:00"
  disponible  Boolean        @default(true)

  empleado    PerfilEmpleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
}

model Cita {
  id            String         @id @default(uuid())
  clienteId     String
  empleadoId    String
  servicioId    String
  fecha         DateTime       @db.Date
  horaInicio    String         
  horaFin       String         
  estado        EstadoCita     @default(PENDIENTE)
  notasCliente  String?
  notasInternas String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  cliente       Usuario        @relation("ClienteCita", fields: [clienteId], references: [id], onDelete: Cascade)
  empleado      PerfilEmpleado @relation("EmpleadoCita", fields: [empleadoId], references: [id], onDelete: Cascade)
  servicio      Servicio       @relation(fields: [servicioId], references: [id], onDelete: Restrict)
  pagos         Pago[]
}

model Pago {
  id          String    @id @default(uuid())
  citaId      String
  monto       Float
  metodoPago  String?   
  estadoPago  String    @default("PENDIENTE") 
  referencia  String?
  fechaPago   DateTime?

  cita        Cita      @relation(fields: [citaId], references: [id], onDelete: Cascade)
}

model Notificacion {
  id        String   @id @default(uuid())
  userId    String
  tipo      String   
  titulo    String
  mensaje   String
  leida     Boolean  @default(false)
  createdAt DateTime @default(now())

  usuario   Usuario  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
