# URL del Worker externo (ej. Railway o Render)
BACKUP_WORKER_URL=https://backup-worker-production.up.railway.app

# Clave secreta compartida HMAC entre Vercel y el Worker para firmar peticiones
BACKUP_WORKER_SECRET=mi-clave-secreta-compartida-hmac-de-produccion

# Habilita o deshabilita la restauración destructiva en producción (true/false)
BACKUP_RESTORE_ENABLED=false

# Proveedor de almacenamiento compatible con S3
BACKUP_STORAGE_PROVIDER=s3
S3_BUCKET=nombre-de-tu-bucket-privado

# Token de seguridad para llamar a la ruta del Cron (/api/cron/backups)
CRON_SECRET=mi-clave-secreta-del-cron-vercel
