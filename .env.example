# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variables de entorno requeridas para el sistema de citas
#
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.local (desarrollo) o configurar en Vercel (producción)
# 2. NUNCA commitear .env.local o cualquier archivo con valores reales al repositorio
# 3. Las variables marcadas con [CRÍTICO] son obligatorias en producción
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de datos (NeonDB / PostgreSQL) ─────────────────────────────────────
# [CRÍTICO] URL de conexión a la base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@host/database?sslmode=require"

# ─── Autenticación JWT ────────────────────────────────────────────────────────
# [CRÍTICO] Secreto para firmar tokens de acceso (access_token)
# Debe ser una cadena aleatoria larga y compleja (mínimo 32 caracteres).
# Generar con: openssl rand -base64 64
JWT_SECRET="REEMPLAZAR_CON_SECRETO_GENERADO_ALEATORIAMENTE"

# [CRÍTICO] Secreto para firmar tokens de refresco (refresh_token)
# Debe ser DIFERENTE al JWT_SECRET
# Generar con: openssl rand -base64 64
JWT_REFRESH_SECRET="REEMPLAZAR_CON_OTRO_SECRETO_DIFERENTE_AL_JWT_SECRET"

# ─── Entorno ─────────────────────────────────────────────────────────────────
# Opciones: development | production | test
NODE_ENV="production"

# ─── URL Base de la aplicación ───────────────────────────────────────────────
# URL base donde se despliega la app (sin slash al final)
NEXT_PUBLIC_APP_URL="https://tu-dominio.vercel.app"

# ─── Configuración de correo (si se usa en el futuro) ────────────────────────
# SMTP_HOST="smtp.proveedor.com"
# SMTP_PORT="587"
# SMTP_USER="tu@correo.com"
# SMTP_PASS="contraseña_smtp"
# SMTP_FROM="nombre@dominio.com"
