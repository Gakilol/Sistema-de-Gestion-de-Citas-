# ─── BASE DE DATOS (NeonDB / PostgreSQL) ──────────────────────────────────────
DATABASE_URL="postgresql://USUARIO:PASSWORD@HOST/neondb?sslmode=require"

# ─── AUTENTICACIÓN Y SEGURIDAD JWT ────────────────────────────────────────────
# Generar claves criptográficas independientes de alta entropía (mínimo 32 caracteres / 256 bits)
# Obligatorio en producción; no existe fallback seguro.
JWT_SECRET="TU_JWT_SECRET_DE_ALTA_ENTROPIA_AQUI"
JWT_REFRESH_SECRET="TU_JWT_REFRESH_SECRET_INDEPENDIENTE_AQUI"

# Secreto opcional para tokens de persistencia de dispositivo
REMEMBER_DEVICE_SECRET="TU_REMEMBER_DEVICE_SECRET_OPCIONAL_AQUI"

# Secreto opcional para proteger enlaces directos al calendario
CALENDAR_LINK_SECRET="TU_CALENDAR_LINK_SECRET_OPCIONAL_AQUI"

# ─── SERVICIO DE CORREO ELECTRÓNICO (SMTP) ────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-correo@ejemplo.com"
SMTP_PASSWORD="tu-app-password-de-gmail"
SMTP_FROM="\"Hairs Style and Salon\" <no-reply@ejemplo.com>"

# ─── INTEGRACIÓN WHATSAPP Y TAREAS PROGRAMADAS ────────────────────────────────
WHATSAPP_API_URL=""
WHATSAPP_API_TOKEN=""
# Obligatorio donde se ejecuten cron; Vercel lo envía como Authorization: Bearer <CRON_SECRET>.
CRON_SECRET="TU_VERCEL_CRON_SECRET_AQUI"

# FLAGS DE DESACTIVACIÓN (Opcional para pruebas)
# DISABLE_EMAILS="false"
# DISABLE_NOTIFICATIONS="false"
# DISABLE_REMINDER_JOBS="false"
# DISABLE_WHATSAPP="false"
