# ==============================================================================
# NOVACITA - ARCHIVO DE CONFIGURACIÓN DE EJEMPLO (.env.example)
# ==============================================================================
# Instrucciones:
# 1. Copie este archivo y renombrelo como `.env` o `.env.local`
# 2. Complete cada una de las variables según su entorno de desarrollo o staging.
# 3. No suba secretos reales al repositorio de control de versiones Git.
# ==============================================================================

# Conexión principal a la Base de Datos (PostgreSQL o NeonDB)
# Ejemplo para desarrollo local: postgresql://postgres:password@localhost:5432/novacita_db?schema=public
# Ejemplo para Neon: postgresql://neondb_owner:contrasena@ep-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# Seguridad y Autenticación
# Secreto utilizado para firmar los tokens JWT del lado de la aplicación
JWT_SECRET="su-clave-secreta-jwt-aqui"
# Secreto opcional utilizado para firmar tokens JWT de refresco
JWT_REFRESH_SECRET="su-clave-secreta-jwt-refresh-aqui"

# URL base del Frontend (requerido para redireccionamientos y CORS)
FRONTEND_URL="http://localhost:3000"

# Nombre público de la aplicación (usado en cabeceras, plantillas de correo, etc.)
NEXT_PUBLIC_APP_NAME="NovaCita - Gestión Profesional"

# Configuración del Servidor de Correo SMTP (Ej. Gmail, SendGrid, etc.)
# Host de SMTP (ej: smtp.gmail.com o smtp.sendgrid.net)
SMTP_HOST="smtp.example.com"
# Puerto SMTP (comúnmente 587 para TLS/STARTTLS o 465 para SSL)
SMTP_PORT=587
# Cuenta de correo o usuario del SMTP
SMTP_USER="no-reply@su-dominio.com"
# Contraseña de la cuenta de correo o token de aplicación SMTP
SMTP_PASSWORD="su-contrasena-o-token-smtp-aqui"
# Dirección y nombre que aparecerá como remitente de los correos
SMTP_FROM="NovaCita <no-reply@su-dominio.com>"

# Integración y Notificaciones de WhatsApp (Opcional)
# URL de la API externa de WhatsApp Gateway
WHATSAPP_API_URL="https://api.whatsapp-gateway.com/send"
# Token de acceso para autenticación con el proveedor de WhatsApp
WHATSAPP_API_TOKEN="su-token-whatsapp-gateway-aqui"

# Tareas Programadas y Automatización (Cron Jobs)
# Clave de seguridad para autenticar peticiones externas de Cron
CRON_SECRET="su-cron-secret-de-seguridad-aqui"
