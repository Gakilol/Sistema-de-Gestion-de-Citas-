# Puerto donde corre el servidor express del worker (para healthcheck)
PORT=4000

# Clave compartida secreta para firmar/verificar HMAC entre Vercel y el Worker
BACKUP_WORKER_SECRET=tu-clave-secreta-compartida-hmac

# Identificador único de este worker (opcional)
BACKUP_WORKER_ID=worker-1

# Base de datos de la APP (donde lee las colas de TrabajoBackup, HistorialBackup y Configuracion)
WORKER_APP_DATABASE_URL=postgresql://usuario:password@host:puerto/dbname?sslmode=require

# Base de datos de Backups (donde ejecuta pg_dump y pg_restore)
# Puede ser la misma anterior o una con más privilegios
BACKUP_DATABASE_URL=postgresql://usuario:password@host:puerto/dbname?sslmode=require

# Configuración de S3 Compatible (AWS, Cloudflare R2, MinIO, etc.)
S3_ACCESS_KEY_ID=tu-key-id
S3_SECRET_ACCESS_KEY=tu-secret-key
S3_BUCKET=nombre-de-tu-bucket
S3_REGION=us-east-1
# Descomentar si usas Cloudflare R2, MinIO o un endpoint personalizado
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Parámetros operacionales
BACKUP_SIGNED_URL_EXPIRATION_MINUTES=10
BACKUP_JOB_TIMEOUT_MINUTES=30
BACKUP_MAX_RETRIES=3
BACKUP_RESTORE_ENABLED=false
